rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function validListing(data) {
      return data.uid == request.auth.uid
        && data.title is string
        && data.title.size() >= 3
        && data.title.size() <= 200
        && data.desc is string
        && data.desc.size() <= 5000
        && data.type in ['deal', 'rental', 'pg', 'job']
        && data.budget is number
        && data.budget >= 25
        && data.budget <= 10000
        && data.lat is number
        && data.lat >= 6
        && data.lat <= 39
        && data.lng is number
        && data.lng >= 66
        && data.lng <= 99
        && data.status in ['active', 'paused'];
    }

    match /listings/{listingId} {
      allow get: if resource.data.status == 'active' || owns(resource.data.uid);
      allow list: if request.query.limit <= 150;
      allow create: if signedIn()
        && validListing(request.resource.data)
        && request.resource.data.popups == 0
        && request.resource.data.visits == 0
        && request.resource.data.claims == 0;
      allow update: if owns(resource.data.uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.popups == resource.data.popups
        && request.resource.data.popupsSentToday == resource.data.popupsSentToday;
      allow delete: if owns(resource.data.uid);
    }

    match /users/{userId} {
      allow get: if owns(userId);
      allow list: if false;
      allow create: if owns(userId);
      allow update: if owns(userId)
        && request.resource.data.wallet <= resource.data.wallet + 500
        && request.resource.data.uid == resource.data.uid;
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /analytics/{doc=**} {
      allow read: if false;
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /upload_logs/{docId} {
      allow read, write: if false;
    }

    match /admin_alerts/{docId} {
      allow read, write: if false;
    }
  }
}
